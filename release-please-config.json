{
	"$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
	"release-type": "rust",
	"include-component-in-tag": false,
	"include-void-in-tag": false,
	"versioning": "default",
	"changelog-sections": [
		"feat",
		"fix",
		"perf",
		"revert",
		"docs",
		"style",
		"refactor",
		"build",
		"ci",
		"test",
		"chore"
	],
	"packages": {
		".": {
			"component": "agentsync",
			"include-void-in-tag": false
		}
	},
	"draft": false,
	"prerelease": false,
	"extra-files": [],
	"single-line": false,
	"commit-message": "chore: release ${version}",
	"tag-message": "chore: release ${version}",
	"pull-request-header": "Release PR",
	"pull-request-title": "chore: release ${version}",
	"pull-request-body": "<!-- release-please-action -->",
	"release-as": null,
	"indicator": null,
	"shard-count": null
}
