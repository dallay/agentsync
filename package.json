{
	"name": "agentsync-root",
	"private": true,
	"workspaces": [
		"npm/agentsync"
	],
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lefthook",
			"sharp"
		]
	},
	"scripts": {
		"update-deps": "pnpm update -i -r --latest",
		"preinstall": "npx only-allow pnpm",
		"prepare": "node scripts/setup.js",
		"agents:sync": "pnpm exec agentsync apply",
		"agents:sync:clean": "pnpm --filter agentsync run clean",
		"biome:fix": "pnpm exec biome check --write .",
		"biome:check": "pnpm exec biome check",
		"precommit": "pnpm exec agentsync apply --dry-run",
		"docs:dev": "pnpm --filter agentsync-docs run dev",
		"docs:start": "pnpm --filter agentsync-docs run start",
		"docs:build": "pnpm --filter agentsync-docs run build",
		"docs:preview": "pnpm --filter agentsync-docs run preview",
		"docs:astro": "pnpm --filter agentsync-docs run astro"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"lefthook": "^2.1.6"
	},
	"version": "1.44.0"
}
